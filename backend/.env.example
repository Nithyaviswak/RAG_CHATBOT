SECRET_KEY=dev-secret-change-in-production

# Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_key_here

# Model settings
# EMBEDDING_PROVIDER values: auto | gemini | local
# auto: use Gemini when key is present; otherwise local sentence-transformers
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=models/embedding-001
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.1

# Storage
UPLOAD_FOLDER=uploads
VECTOR_DB_FOLDER=vector_db
MAX_CONTENT_LENGTH=52428800

# RAG tuning
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_K=4
# Chat retrieval mode: vector | long_context | hybrid
CHAT_RETRIEVAL_MODE=vector
# Used in long_context/hybrid fallback to cap prompt size
LONG_CONTEXT_MAX_CHARS=300000
MEMORY_WINDOW=10

# CORS
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost,http://127.0.0.1
